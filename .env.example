# URL du backend Laravel (fallback en dur dans le code si absent)
NEXT_PUBLIC_BACKEND_URL=

# Paiements Kkiapay — clé PUBLIQUE uniquement (le widget s'ouvre côté client).
# Les clés privée/secrète restent côté backend (voir backend/.env).
NEXT_PUBLIC_KKIAPAY_PUBLIC_KEY=
NEXT_PUBLIC_KKIAPAY_SANDBOX=true
